{
  "name": "opencode-chat",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.6.0",
  "publisher": "zeug-zz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeug-zz/opencode-chat"
  },
  "homepage": "https://github.com/zeug-zz/opencode-chat#readme",
  "bugs": {
    "url": "https://github.com/zeug-zz/opencode-chat/issues"
  },
  "keywords": [
    "opencode",
    "ai",
    "chat",
    "llm",
    "coding-assistant"
  ],
  "icon": "media/icon.png",
  "preview": true,
  "qna": false,
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onView:opencode-chat.chatView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencode-chat",
          "title": "OpenCode",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "opencode-chat": [
        {
          "type": "webview",
          "id": "opencode-chat.chatView",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs && vite build",
    "build:ext": "node esbuild.mjs",
    "build:webview": "vite build",
    "watch:ext": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:ext": "vitest run --config vitest.config.ext.ts",
    "test:ext:watch": "vitest --config vitest.config.ext.ts",
    "test:all": "vitest run --config vitest.config.ts && vitest run --config vitest.config.ext.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.125.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "jsdom": "^28.1.0",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@opencode-chat/agent-opencode": "workspace:*",
    "@opencode-chat/core": "workspace:*",
    "diff": "^8.0.0",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked-katex-extension": "^5.1.10",
    "mermaid": "^11.15.0",
    "react-icons": "^5.5.0"
  }
}
